rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global default-deny safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(resourceData) {
      return isSignedIn() && resourceData.ownerId == request.auth.uid;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function agentePath() {
      return /databases/$(database)/documents/agentes/$(request.auth.uid);
    }

    function hasLegacyScope() {
      return !exists(agentePath());
    }

    function hasAreaAccess(areaId) {
      return hasLegacyScope()
        || (
          areaId is string
          && exists(agentePath())
          && get(agentePath()).data.areaIds is list
          && get(agentePath()).data.areaIds.hasAny([areaId])
        );
    }

    function hasRuaExtraAccess(ruaId) {
      return hasLegacyScope()
        || (
          ruaId is string
          && exists(agentePath())
          && get(agentePath()).data.ruaIdsExtras is list
          && get(agentePath()).data.ruaIdsExtras.hasAny([ruaId])
        );
    }

    function hasTerritoryAccess(areaId, ruaId) {
      return hasAreaAccess(areaId) || hasRuaExtraAccess(ruaId);
    }

    function isValidAgente(data) {
      return data.ownerId == request.auth.uid
        && data.areaIds is list
        && data.ruaIdsExtras is list
        && data.keys().hasAll(['ownerId', 'areaIds', 'ruaIdsExtras'])
        && data.keys().size() >= 3
        && data.keys().size() <= 5
        && (!('createdAt' in data) || data.createdAt is timestamp)
        && (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    match /agentes/{agenteId} {
      allow create: if isSignedIn()
        && agenteId == request.auth.uid
        && isValidAgente(incoming())
        && incoming().ownerId == request.auth.uid;

      allow update: if isSignedIn()
        && agenteId == request.auth.uid
        && isValidAgente(incoming())
        && isOwner(existing())
        && incoming().ownerId == existing().ownerId;

      allow get: if isSignedIn()
        && agenteId == request.auth.uid
        && ( !exists(/databases/$(database)/documents/agentes/$(agenteId)) || isOwner(existing()) );

      allow list: if false;
      allow delete: if false;
    }

    function isValidIdentificacao(data) {
      return data is map
        && data.keys().hasAll(['cpfCnsCidadao', 'nomeCompleto', 'dataNascimento', 'sexo'])
        && data.cpfCnsCidadao is string && data.cpfCnsCidadao.size() > 0 && data.cpfCnsCidadao.size() <= 20
        && data.nomeCompleto is string && data.nomeCompleto.size() > 0 && data.nomeCompleto.size() <= 120
        && data.dataNascimento is string && data.dataNascimento.size() >= 8 && data.dataNascimento.size() <= 20
        && data.sexo is string && (data.sexo == 'Masculino' || data.sexo == 'Feminino' || data.sexo == 'Outro')
        && (!('nomeSocial' in data) || (data.nomeSocial is string && data.nomeSocial.size() <= 120))
        && (!('cpfCnsResponsavelFamiliar' in data) || (data.cpfCnsResponsavelFamiliar is string && data.cpfCnsResponsavelFamiliar.size() <= 20))
        && (!('racaCor' in data) || (data.racaCor is string && data.racaCor.size() <= 30))
        && (!('etnia' in data) || (data.etnia is string && data.etnia.size() <= 80))
        && (!('nissPisPasep' in data) || (data.nissPisPasep is string && data.nissPisPasep.size() <= 20))
        && (!('nomeMae' in data) || (data.nomeMae is string && data.nomeMae.size() <= 120))
        && (!('nomePai' in data) || (data.nomePai is string && data.nomePai.size() <= 120))
        && (!('cidadaoResponsavelFamiliar' in data) || data.cidadaoResponsavelFamiliar is bool)
        && data.keys().size() <= 20;
    }

    function isValidEnderecoTerritorio(data) {
      return data is map
        && data.keys().hasAll(['areaAtendimento', 'rua', 'casa'])
        && data.areaAtendimento is string && data.areaAtendimento.size() > 0 && data.areaAtendimento.size() <= 100
        && data.rua is string && data.rua.size() > 0 && data.rua.size() <= 150
        && data.casa is string && data.casa.size() > 0 && data.casa.size() <= 50
        && (!('areaId' in data) || (data.areaId is string && isValidId(data.areaId)))
        && (!('ruaId' in data) || (data.ruaId is string && isValidId(data.ruaId)))
        && (!('casaId' in data) || (data.casaId is string && isValidId(data.casaId)))
        && (!('microarea' in data) || (data.microarea is string && data.microarea.size() <= 50))
        && (!('foraArea' in data) || data.foraArea is bool)
        && (!('telefoneCelular' in data) || (data.telefoneCelular is string && data.telefoneCelular.size() <= 20))
        && (!('email' in data) || (data.email is string && data.email.size() <= 120))
        && data.keys().size() <= 13;
    }

    function hasValidCasaReference(data) {
      return !('casaId' in data)
        || (data.casaId is string && isValidId(data.casaId));
    }

    function isValidSocioeconomico(data) {
      return data is map
        && (!('parentescoResponsavelFamiliar' in data) || (data.parentescoResponsavelFamiliar is string && data.parentescoResponsavelFamiliar.size() <= 80))
        && (!('frequentaEscolaCreche' in data) || data.frequentaEscolaCreche is bool)
        && (!('cursoFrequenta' in data) || (data.cursoFrequenta is string && data.cursoFrequenta.size() <= 120))
        && (!('situacaoMercadoTrabalho' in data) || (data.situacaoMercadoTrabalho is string && data.situacaoMercadoTrabalho.size() <= 120))
        && (!('criancas0a9ComQuemFica' in data) || data.criancas0a9ComQuemFica is list)
        && (!('cuidadorTradicional' in data) || data.cuidadorTradicional is bool)
        && (!('participaGrupoComunitario' in data) || data.participaGrupoComunitario is bool)
        && (!('planoSaudePrivado' in data) || data.planoSaudePrivado is bool)
        && (!('membroComunidadeTradicional' in data) || data.membroComunidadeTradicional is bool)
        && (!('orientacaoSexualInformada' in data) || data.orientacaoSexualInformada is bool)
        && (!('orientacaoSexual' in data) || (data.orientacaoSexual is string && data.orientacaoSexual.size() <= 60))
        && (!('identidadeGeneroInformada' in data) || data.identidadeGeneroInformada is bool)
        && (!('identidadeGenero' in data) || (data.identidadeGenero is string && data.identidadeGenero.size() <= 60))
        && data.keys().size() <= 20;
    }

    function isValidSaude(data) {
      return data is map
        && (!('deficiencias' in data) || data.deficiencias is list)
        && (!('triagemInsegurancaSemDinheiroComida' in data) || data.triagemInsegurancaSemDinheiroComida is bool)
        && (!('triagemInsegurancaSemComerPorFaltaDinheiro' in data) || data.triagemInsegurancaSemComerPorFaltaDinheiro is bool)
        && (!('condicoesReferidas' in data) || data.condicoesReferidas is list)
        && (!('doencasRespiratorias' in data) || data.doencasRespiratorias is list)
        && (!('problemasRins' in data) || data.problemasRins is list)
        && (!('internacaoUltimos12Meses' in data) || data.internacaoUltimos12Meses is bool)
        && (!('causaInternacao' in data) || (data.causaInternacao is string && data.causaInternacao.size() <= 200))
        && (!('problemasSaudeMental' in data) || data.problemasSaudeMental is bool)
        && (!('acamado' in data) || data.acamado is bool)
        && (!('domiciliado' in data) || data.domiciliado is bool)
        && (!('plantasMedicinais' in data) || data.plantasMedicinais is bool)
        && (!('plantasMedicinaisQuais' in data) || (data.plantasMedicinaisQuais is string && data.plantasMedicinaisQuais.size() <= 200))
        && data.keys().size() <= 20;
    }

    // PESSOA ENTITY VALIDATION
    function isValidPessoa(data) {
      return data.nome is string && data.nome.size() > 0 && data.nome.size() <= 100
        && data.idade is number && data.idade >= 0 && data.idade <= 120
        && data.sexo is string && (data.sexo == 'Masculino' || data.sexo == 'Feminino' || data.sexo == 'Outro')
        && data.doencas is list && data.doencas.size() <= 10
        && data.areaAtendimento is string && data.areaAtendimento.size() > 0 && data.areaAtendimento.size() <= 100
        && data.rua is string && data.rua.size() > 0 && data.rua.size() <= 150
        && data.casa is string && data.casa.size() > 0 && data.casa.size() <= 50
        && (!('areaId' in data) || (data.areaId is string && isValidId(data.areaId)))
        && (!('ruaId' in data) || (data.ruaId is string && isValidId(data.ruaId)))
        && (!('casaId' in data) || (data.casaId is string && isValidId(data.casaId)))
        && (!('visitaPendente' in data) || data.visitaPendente is bool)
        && (!('schemaVersion' in data) || data.schemaVersion == 2)
        && (!('identificacao' in data) || isValidIdentificacao(data.identificacao))
        && (!('enderecoTerritorio' in data) || isValidEnderecoTerritorio(data.enderecoTerritorio))
        && (!('socioeconomico' in data) || isValidSocioeconomico(data.socioeconomico))
        && (!('saude' in data) || isValidSaude(data.saude))
        && hasValidCasaReference(data)
        && data.ownerId == request.auth.uid
        && data.keys().hasAll(['nome', 'idade', 'sexo', 'doencas', 'areaAtendimento', 'rua', 'casa', 'createdAt', 'updatedAt', 'ownerId'])
        && data.keys().hasOnly([
          'nome', 'idade', 'sexo', 'doencas', 'areaAtendimento', 'rua', 'casa', 'createdAt', 'updatedAt', 'ownerId',
          'areaId', 'ruaId', 'casaId', 'visitaPendente', 'schemaVersion', 'identificacao', 'enderecoTerritorio', 'socioeconomico', 'saude'
        ]);
    }

    match /pessoas/{pessoaId} {
      allow create: if isSignedIn() 
        && isValidId(pessoaId) 
        && isValidPessoa(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time
        && hasTerritoryAccess(incoming().areaId, incoming().ruaId);
        
      allow update: if isSignedIn()
        && isValidId(pessoaId)
        && isOwner(existing())
        && isValidPessoa(incoming())
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && incoming().ownerId == existing().ownerId
        && hasTerritoryAccess(incoming().areaId, incoming().ruaId);
        
      allow delete: if isSignedIn()
        && isOwner(existing());
        
      allow get: if isSignedIn()
        && isOwner(existing());
        
      allow list: if isSignedIn()
        && resource.data.ownerId == request.auth.uid;
    }

    // TERRITORIO: single document per user containing all areas, ruas and casas
    match /territorio/{userId} {
      allow read: if isSignedIn() && userId == request.auth.uid;
      allow write: if isSignedIn()
        && userId == request.auth.uid
        && incoming().ownerId == request.auth.uid;
    }

    // ATENDIMENTO ENTITY VALIDATION
    function isValidAtendimento(data) {
      return data.pessoaId is string && data.pessoaId.size() <= 128
        && data.dataVisita is timestamp
        && data.descricao is string && data.descricao.size() > 0 && data.descricao.size() <= 1000
        && data.ownerId == request.auth.uid
        && data.keys().hasAll(['pessoaId', 'dataVisita', 'descricao', 'createdAt', 'ownerId'])
        && data.keys().size() == 5;
    }

    match /atendimentos/{atendimentoId} {
      // Relational Sync: prevent orphaned records by checking that the referenced patient exists and is owned by the user
      allow create: if isSignedIn() 
        && isValidId(atendimentoId) 
        && isValidAtendimento(incoming())
        && incoming().createdAt == request.time
        && exists(/databases/$(database)/documents/pessoas/$(incoming().pessoaId))
        && hasTerritoryAccess(
          get(/databases/$(database)/documents/pessoas/$(incoming().pessoaId)).data.areaId,
          get(/databases/$(database)/documents/pessoas/$(incoming().pessoaId)).data.ruaId
        )
        && get(/databases/$(database)/documents/pessoas/$(incoming().pessoaId)).data.ownerId == request.auth.uid;

      allow update: if isSignedIn()
        && isValidId(atendimentoId)
        && isOwner(existing())
        && isValidAtendimento(incoming())
        && incoming().createdAt == existing().createdAt
        && incoming().ownerId == existing().ownerId
        && exists(/databases/$(database)/documents/pessoas/$(incoming().pessoaId))
        && hasTerritoryAccess(
          get(/databases/$(database)/documents/pessoas/$(incoming().pessoaId)).data.areaId,
          get(/databases/$(database)/documents/pessoas/$(incoming().pessoaId)).data.ruaId
        )
        && incoming().pessoaId == existing().pessoaId; // immutable

      allow delete: if isSignedIn()
        && isOwner(existing());

      allow get: if isSignedIn()
        && isOwner(existing());

      allow list: if isSignedIn()
        && resource.data.ownerId == request.auth.uid;
    }
  }
}
